# ─────────────────────────────────────────────────────────────
# MongoDB — odaberite JEDNU opciju
# ─────────────────────────────────────────────────────────────

# Opcija A: Atlas (tim / produkcija)
# U Atlasu: Network Access → Add Current IP (ili 0.0.0.0/0 samo za dev)
# Na Renderu: Network Access → Allow Access from Anywhere (0.0.0.0/0)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/rodendaonica?retryWrites=true&w=majority

# Opcija B: Lokalni dev BEZ Atasa (preporuka ako dobivate whitelist grešku)
# MONGO_URI=memory
# AUTO_SEED=true

# Opcija C: Lokalni MongoDB (mongodb-community ili Docker)
# MONGO_URI=mongodb://127.0.0.1:27017/rodendaonica

# Demo korisnici (Ana / partner) — učitaj ako je baza prazna
# Na Renderu: AUTO_SEED=true (samo za staging / demo)
AUTO_SEED=false

JWT_SECRET=dev-secret-promijeni-u-produkciji
JWT_EXPIRES_IN=7d
PORT=3000
# Više domena odvojeno zarezom (lokalni Vite + Render frontend)
CORS_ORIGIN=http://localhost:5173,https://rodendaonica.onrender.com
STRIPE_SECRET_KEY=

# Online plaćanje (Stripe) — isključeno dok se ne testira tržište
# Aktivacija: STRIPE_ENABLED=true + ključevi iz Stripe Dashboarda
STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# URL frontenda (linkovi u emailovima)
# Render: APP_URL=https://rodendaonica.onrender.com
APP_URL=http://localhost:5173

# Email — bez SMTP-a poruke se ispisuju u server konzolu (dev)
EMAIL_FROM=Rodendaonica <noreply@rodendaonica.hr>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
