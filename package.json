{
  "name": "rodendaonica",
  "private": true,
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "db:seed": "npm run db:seed --prefix server",
    "db:up": "docker compose up -d mongo",
    "db:down": "docker compose down",
    "test": "npm run test --prefix server && npm run test --prefix client",
    "test:server": "npm run test --prefix server",
    "test:client": "npm run test --prefix client",
    "typecheck": "npm run typecheck --prefix client && npm run build --prefix server",
    "e2e:install": "playwright install chromium",
    "e2e:demo": "playwright test e2e/demo-usage-trail.spec.ts",
    "e2e:demo:headed": "playwright test e2e/demo-usage-trail.spec.ts --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "concurrently": "^9.2.1"
  }
}
