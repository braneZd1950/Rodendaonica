# API mod: mock (development) | http (produkcija / staging s backendom)
VITE_API_MODE=mock

# Bazni URL backend API-ja (koristi se kad je VITE_API_MODE=http)
# Preporuka uz Vite proxy: /api
VITE_API_BASE_URL=/api
# Ili direktno: http://localhost:3000/api

# Verzija aplikacije (opcionalno, prikaz u postavkama / logovima)
VITE_APP_VERSION=0.1.0
