# API mod: mock (development) | http (produkcija / staging s backendom)
VITE_API_MODE=mock

# Bazni URL backend API-ja (koristi se kad je VITE_API_MODE=http)
# Lokalno uz Vite proxy:
VITE_API_BASE_URL=/api

# Alternativa — origin backenda (automatski dodaje /api):
# VITE_API_URL=http://localhost:3000

# Render (frontend Environment):
# VITE_API_MODE=http
# VITE_API_URL=https://rodendaonica-api.onrender.com

# Verzija aplikacije (opcionalno)
VITE_APP_VERSION=0.1.0
